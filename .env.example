APP_ENV=development
SECRET_KEY=change-this-to-a-long-random-value

SQLITE_TIMEOUT_SECONDS=30
SQLITE_BUSY_TIMEOUT_MS=30000
SQLITE_JOURNAL_MODE=WAL
SQLITE_SYNCHRONOUS=NORMAL

LOG_LEVEL=INFO
ACCESS_LOG_ENABLED=1
EVENT_LOG_ENABLED=1
RESPONSE_SUMMARY_LOG_ENABLED=1

AUTH_COOKIE_NAME=token
AUTH_COOKIE_HTTPONLY=1
AUTH_COOKIE_SAMESITE=Strict
AUTH_COOKIE_SECURE=0

CUSTOMER_LIST_CACHE_SCHEDULER_ENABLED=1
CUSTOMER_LIST_CACHE_REFRESH_HOUR=6
CUSTOMER_LIST_CACHE_REFRESH_MINUTE=0
